{
  "name": "u-spy",
  "version": "0.39.1",
  "type": "module",
  "bin": {
    "u-spy": "bin/u-spy.js"
  },
  "main": "dist/index.iife.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.iife.js",
      "import": "./dist/index.iife.js",
      "require": "./dist/index.iife.js"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.js"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "pre-build": "tsx pre-build",
    "build-js": "tsdown",
    "build-dts": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build-only": "run-s build-js build-dts",
    "build": "run-s pre-build build-only",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "biome check src",
    "prepare": "playwright install",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [],
  "author": "tomsdoo",
  "license": "MIT",
  "description": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomsdoo/u-spy.git"
  },
  "bugs": {
    "url": "https://github.com/tomsdoo/u-spy/issues"
  },
  "homepage": "https://tomsdoo.github.io/u-spy/",
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "26.0.0",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "npm-run-all2": "9.0.2",
    "playwright": "1.61.0",
    "tsc-alias": "1.8.17",
    "tsdown": "^0.22.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitepress": "1.6.4",
    "vitest": "4.1.9"
  },
  "overrides": {
    "vitepress": {
      "vite": "^8.0.0",
      "@vitejs/plugin-vue": "^6.0.0"
    }
  }
}
